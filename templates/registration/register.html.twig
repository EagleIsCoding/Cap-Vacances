{% extends 'base.html.twig' %}

{% block title %}Inscription - Cap Vacances{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card p-4 shadow">
            <h1 class="fw-bold mb-4">Créer un compte</h1>

            {{ form_start(registrationForm) }}
                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_row(registrationForm.nomClient, {'attr': {'class': 'form-control'}}) }}
                    </div>
                    <div class="col-md-6 mb-3">
                        {{ form_row(registrationForm.prenomClient, {'attr': {'class': 'form-control'}}) }}
                    </div>
                </div>

                <div class="mb-3">
                    {{ form_row(registrationForm.email, {'attr': {'class': 'form-control'}}) }}
                </div>
                
                <div class="mb-4">
                    {{ form_row(registrationForm.plainPassword, {
                        'label': 'Mot de passe',
                        'attr': {'class': 'form-control'}
                    }) }}
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100">Finaliser l'inscription</button>
            {{ form_end(registrationForm) }}
            
            <p class="mt-3 text-center text-muted">
                Déjà inscrit ? <a href="{{ path('app_login') }}">Connectez-vous</a>
            </p>
        </div>
    </div>
</div>
{% endblock %}