{% extends 'base.html.twig' %}

{% block title %}Mon Compte - Cap Vacances{% endblock %}

{% block body %}
<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm p-4 mb-4">
            <h4 class="fw-bold mb-3">Mes Informations</h4>
            <p><strong>Email :</strong> {{ app.user.email }}</p>
            <p><strong>Nom :</strong> {{ client.nomClient|default('Non renseigné') }}</p>
            <p><strong>Prénom :</strong> {{ client.prenomClient|default('Non renseigné') }}</p>
            <p><strong>Rue :</strong> {{ client.rueClient|default('Non renseignée') }}</p>
            
            <a href="{{ path('app_account_edit') }}" class="btn btn-primary w-100 mt-3">
                Modifier mon profil
            </a>
        </div>
    </div>

    {# Colonne Réservations #}
    <div class="col-md-8">
        <div class="card shadow-sm p-4">
            <h4 class="fw-bold mb-4">Mes Réservations</h4>
            
            {% if reservations is empty %}
                <div class="alert alert-light text-center">
                    Vous n'avez pas encore de réservation. <br>
                    <a href="{{ path('app_studio_index') }}" class="alert-link">Découvrir nos studios</a>
                </div>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Studio</th>
                                <th>Dates</th>
                                <th class="text-center">Personnes</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for res in reservations %}
                            <tr>
                                <td class="fw-bold text-primary">{{ res.studio.nomStudio }}</td>
                                <td>
                                    <small>Du {{ res.dateDebutReservation|date('d/m/Y') }}</small><br>
                                    <small>Au {{ res.dateFinReservation|date('d/m/Y') }}</small>
                                </td>
                                <td class="text-center">{{ res.nbPersonnesReservation }}</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}